---
import HeaderLink from './HeaderLink.astro';
import SocialLinks from './SocialLinks.astro';
import { SITE_TITLE } from '../consts';
---

<header>
  <nav>
    <h2 class="site-title"><a href="/">{SITE_TITLE}</a></h2>

    <div class="nav-menu" id="nav-menu">
      <div class="internal-links">
        <HeaderLink href="/">Home</HeaderLink>
        <HeaderLink href="/about">About Me</HeaderLink>
        <HeaderLink href="/resume">My Resume</HeaderLink>
        <HeaderLink href="/projects">My Projects</HeaderLink>
        <HeaderLink href="/blog">My Blogs</HeaderLink>
        <HeaderLink href="/contactme">Contact Me</HeaderLink>
      </div>
    </div>

    <div class="header-right">
      <SocialLinks />
    </div>

    <button class="hamburger" aria-label="Toggle menu" aria-expanded="false" aria-controls="nav-menu">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </nav>
</header>

<style>
  header {
    margin: 0;
    padding: 0 1.5em;
    box-shadow: 0 2px 8px rgba(var(--black), 5%);
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(255, 255, 255, 0.7);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }

  /* Three columns: title (left) | menu (center) | social (right) */
  nav {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 1em;
  }

  .site-title {
    margin: 0;
    font-size: 1em;
    justify-self: start;
    white-space: nowrap;
  }
  .site-title a,
  .site-title a.active {
    text-decoration: none;
  }

  .nav-menu {
    justify-self: center;
  }
  .internal-links {
    display: flex;
    align-items: center;
  }

  .header-right {
    justify-self: end;
  }

nav a {
	padding: 1em 0.5em;
	color: rgb(var(--black));
	border-bottom: 4px solid transparent;
	text-decoration: none;
	white-space: nowrap;
}

nav a.active {
  border-bottom-color: rgb(var(--accent));
}

  /* Hamburger — hidden on desktop */
  .hamburger {
    display: none;
    flex-direction: column;
    justify-content: space-between;
    width: 28px;
    height: 22px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    justify-self: end;
    z-index: 60;
  }
  .hamburger span {
  display: block;
  height: 3px;
  width: 100%;
  background: rgb(var(--black));
  border-radius: 2px;
  transition: transform 0.3s ease, opacity 0.3s ease;
}
  .hamburger.open span:nth-child(1) {
    transform: translateY(9.5px) rotate(45deg);
  }
  .hamburger.open span:nth-child(2) {
    opacity: 0;
  }
  .hamburger.open span:nth-child(3) {
    transform: translateY(-9.5px) rotate(-45deg);
  }

  @media (max-width: 768px) {
    /* Mobile: title left, hamburger right, menu + social drop into the panel */
    nav {
      grid-template-columns: 1fr auto;
    }
    .hamburger {
      display: flex;
    }

    .nav-menu {
      grid-column: 1 / -1;
      justify-self: stretch;
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.35s ease;
    }
    .nav-menu.open {
      max-height: 100vh;
    }
    .internal-links {
      flex-direction: column;
      align-items: stretch;
    }

    .header-right {
      grid-column: 1 / -1;
      justify-self: stretch;
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.35s ease;
      display: flex;
      justify-content: center;
    }
    .header-right.open {
      max-height: 100vh;
      padding: 0.5em 0 1em;
    }

    nav a {
      padding: 0.8em 1em;
      border-bottom: 1px solid rgba(var(--black), 8%);
    }
    nav a.active {
		border-bottom-color: rgb(var(--accent));
		}
  }
</style>

<script>
  const hamburger = document.querySelector('.hamburger');
  const menu = document.querySelector('.nav-menu');
  const right = document.querySelector('.header-right');

  function setOpen(open) {
    menu?.classList.toggle('open', open);
    right?.classList.toggle('open', open);
    hamburger?.classList.toggle('open', open);
    hamburger?.setAttribute('aria-expanded', String(open));
  }

  hamburger?.addEventListener('click', () => {
    const open = !hamburger.classList.contains('open');
    setOpen(open);
  });

  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => setOpen(false));
  });
</script>