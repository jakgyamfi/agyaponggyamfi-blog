---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
import { Image } from 'astro:assets';
import linkedinIcon from '../assets/linkedin.png';
import githubIcon from '../assets/github.jpg';
---

<header>
	<nav>
		<h2><a href="/">{SITE_TITLE}</a></h2>
		<div class="internal-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
		</div>
		<div class="social-links">
			<a href="https://www.linkedin.com/in/jakgyamfi/" target="_blank">
				<span class="sr-only">Find me on LinkedIn</span>
				<Image src={linkedinIcon} alt="LinkedIn" width={45} height={24} />			
			</a>

			<a href="/resume.pdf" class="resume-btn">
				<span class="rb-prompt">agyapong:~$</span>
				<span class="rb-cmd">view my resume</span>
				<span class="rb-cursor"></span>
			</a>

			<a href="hhttps://github.com/jakgyamfi" target="_blank">
				<span class="sr-only">Find me on Github</span>
				<Image src={githubIcon} alt="Github" width={45} height={24} />			
			</a>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: white;
		box-shadow: 0 2px 8px rgba(var(--black), 5%);
	}
	h2 {
		margin: 0;
		font-size: 1em;
	}

	h2 a,
	h2 a.active {
		text-decoration: none;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	nav a {
		padding: 1em 0.5em;
		color: var(--black);
		border-bottom: 4px solid transparent;
		text-decoration: none;
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--accent);
	}
	.social-links,
	.social-links a {
		display: flex;
	}
	@media (max-width: 720px) {
		.social-links {
			display: none;
		}
	}
	.resume-btn{display:inline-flex;align-items:center;gap:12px;font-family:'JetBrains Mono',ui-monospace,monospace;font-size:15px;font-weight:500;text-decoration:none;background:#161b22;border:1px solid rgba(77,139,255,.45);padding:14px 22px;border-radius:999px;transition:transform .22s ease,box-shadow .22s ease,border-color .22s ease,background .22s ease}
	.resume-btn:hover{background:#1b2330;border-color:#4d8bff;transform:translateY(-2px);box-shadow:0 10px 26px -8px rgba(77,139,255,.55)}
	.rb-prompt{color:#5b6b7d}
	.rb-cmd{color:#e6edf3}
	.rb-cursor{width:8px;height:17px;background:#4d8bff;border-radius:1px;display:inline-block;animation:rb-blink 1.05s steps(1) infinite}
	@keyframes rb-blink{0%,49%{opacity:1}50%,100%{opacity:0}}
</style>
