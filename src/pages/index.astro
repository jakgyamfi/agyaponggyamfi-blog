---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
			<main>
				<section class="hero">
					<p class="eyebrow">Cloud Security Engineer • DevSecOps • AI Infrastructure • MCP Security</p> 

					<h3> 
					Cloud Security Engineer securing AI agents, MCP servers, and the cloud infrastructure they depend on. 
					</h3> 

						<p> I build and secure cloud environments with a focus on identity, infrastructure as code, CI/CD pipelines, monitoring, and practical security controls for modern application and AI-enabled systems. 
						</p> 

						<p> 
						My work sits at the intersection of cloud engineering, DevSecOps, technical support, and cybersecurity: designing secure infrastructure, troubleshooting production issues, hardening access paths, and documenting the reasoning behind reliable security decisions. 
						</p> 

					<div class="hero-links"> 
						<a href="/resume">View Resume</a> 
						<a href="/projects">View Projects</a> 
						<a href="/blog">Read Technical Notes</a> 
						<a href="/contact">Contact Me</a> 
					</div> 
				</section> 

				<section class="proof"> 
					<h3>Where I add value</h3> 
					<div class="proof-grid"> 
						
						<article> 
						<h3>Cloud Security Engineering</h3> 
							<p> 
							Securing AWS and cloud-connected environments through IAM design, certificate management, network controls, encryption, logging, monitoring, and incident-focused troubleshooting. 
							</p> 
						</article> 
						<article> 
						<h3>DevSecOps & Automation</h3> 
							<p> 
							Building repeatable infrastructure with Terraform, CloudFormation, GitHub Actions, and CI/CD workflows that reduce manual drift and improve security consistency. 
							</p> 
						</article> 
						<article> 
						<h3>Keyless DevSecOps</h3> 
							<p> 
							Eliminating long-lived credentials with OIDC and IAM Roles Anywhere, and enforcing policy-as-code gates (Checkov, tfsec, Trivy) in CI/CD.
							</p> 
						</article> 						
						<article> 
						<h3>AI Infrastructure Security</h3> 
							<p> 
							Studying and documenting how to secure AI agents, MCP servers, cloud identities, tool access, secrets, logs, and the infrastructure that supports AI-enabled systems. 
							</p> 
						</article> 

						<article> 
							<h3>Production Troubleshooting</h3> 
							<p> 
							Bringing a support-engineering mindset to security: logs, packet captures, API testing, RCA, documentation, and clear communication during high-pressure incidents. 
							</p> 
						</article> 
					</div> 
				</section> 
				
				<section class="focus"> 
					<h3>Technical focus areas</h3> 
					<ul> <li>AWS identity, IAM roles, trust policies, Identity Center, and least privilege</li> 
					<li>Terraform, CloudFormation, GitHub Actions, and secure CI/CD workflows</li> 
					<li>Cloud logging, monitoring, root-cause analysis, and incident response</li> 
					<li>TLS certificates, API troubleshooting, Postman, Burp Suite, ZAP, and Wireshark</li> 
					<li>MCP server security, AI agent infrastructure, and emerging AI security risks</li> 
					</ul> 
				</section> 
				
				<section class="recruiter-cta"> 
					<h3>Open to cloud security, DevSecOps, and AI infrastructure security roles</h3> 
					<p> I am especially interested in roles where cloud infrastructure, security, automation, troubleshooting, and AI-enabled systems meet. 
					</p> 
					<a href="/resume">Review my resume</a> 
				</section>
			</main>
		<Footer />
	</body>
</html>
