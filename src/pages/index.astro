---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
			<main>
			<section class="hero">
				<p class="eyebrow">Cloud Security • DevSecOps • AI Infrastructure</p>

				<h1>Cloud Security Engineer securing the cloud infrastructure behind AI agents, MCP servers, and modern software.</h1>

				<p>
				I write about the practical work of securing cloud environments, CI/CD pipelines,
				MCP servers, and AI-enabled systems — focusing on the decisions, tradeoffs,
				risks, and lessons behind real technical implementation.
				</p>

				<p>
				My goal is to document how secure systems are designed, hardened, monitored,
				automated, and improved over time without exposing sensitive implementation details.
				</p>

				<div class="hero-links">
				<a href="/blog">Read the Blog</a>
				<a href="/about">About Me</a>
				<a href="/resume">My Resume</a>
				</div>
			</section>

			<section class="focus">
				<h2>What I write about</h2>

				<ul>
				<li>Securing AWS cloud infrastructure and identity boundaries</li>
				<li>Hardening CI/CD pipelines and infrastructure-as-code workflows</li>
				<li>Protecting MCP servers, AI agents, and the systems they connect to</li>
				<li>Monitoring, logging, incident response, and operational lessons</li>
				<li>Cloud security architecture, automation, and practical troubleshooting</li>
				</ul>
			</section>
			</main>
		<Footer />
	</body>
</html>
