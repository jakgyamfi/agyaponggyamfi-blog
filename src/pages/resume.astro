---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const PAGE_TITLE = 'Resume - Agyapong K. Gyamfi';
const PAGE_DESCRIPTION =
	'Cloud Security Engineer securing AI agents, MCP servers, and the cloud infrastructure they depend on.';

// --- Resume data -----------------------------------------------------------
const contact = {
	name: 'Agyapong Gyamfi',
	email: 'gyamfi.agyapong@yahoo.com',
	phone: '785-317-3828',
	location: 'Cary, NC',
	linkedin: 'https://linkedin.com/in/jakgyamfi/',
	github: 'https://github.com/jakgyamfi',
};

const summary =
	'Cloud Security Engine, currently my work sits at the intersection of cloud engineering, DevSecOps, technical support, and cybersecurity: designing secure infrastructure, troubleshooting production issues, hardening access paths, and creating runbooks. Securing cloud infrastructure, identity federation, DevSecOps pipelines, multi-cloud technical support — resolving IAM and role-assumption failures, TLS/certificate binding, and firewall, API-security issues, and incident triage. I build and hardens Terraform-based secure baselines, least-privilege IAM, keyless CI/CD (Federation OIDC, IAM Roles Anywhere, TPM-backed certificates), and centralized detection-and-response, GitHub Actions deployments, logging, and detection-focused security controls. Holds an MS in Cybersecurity, AWS Solutions Architect and AWS Security – Specialty certificates. Extending this foundation into AI/LLM security — securing AI agents, MCP servers, and the cloud infrastructure they run on.';

const experience = [
	{
		role: 'Cloud Engineer',
		company: 'G&A Nexus Inc',
		dates: '02/2025 - 04/2026',
		location: 'Raleigh, NC',
		bullets: [
			'Keyless CI/CD Federation: Eliminated long-lived AWS keys by implementing OIDC federation, IAM Roles Anywhere, and TPM-backed certificates; hardened GitHub Actions environments, secrets handling, and pre-deployment scanning.',
			'Multi-Account Architecture: Designed multi-account AWS structure with Organizations, an OIDC federation landing account, and controlled role chaining — spanning landing zones, networking, IAM strategy, disaster recovery, cost, and security architecture.',
			'Identity & Access: Implemented least-privilege access with AWS Identity Center, IAM roles, permission boundaries, and trust policies; enforced controlled cross-account role assumption and removed long-lived IAM users where feasible.',
			'Infrastructure as Code: Built VPC, EC2, RDS, and IAM requirements into Terraform and CloudFormation modules promoted as the team standard for repeatable, drift-free delivery.',
			'Cost Optimization: Drove cost optimization by decommissioning redeployable EC2 instances, purchasing savings plans, leveraging autoscaling, and right-sizing instances.',
			'Governance & Compliance: Established multi-account governance with AWS Organizations, Control Tower concepts, and AWS Config conformance packs for centralized policy enforcement and continuous configuration monitoring.',
			'Network & Workload Security: Hardened VPC, EC2, and RDS workloads with subnetting, VPC Flow Logs, encrypted EBS/RDS volumes, and KMS-managed keys aligned to workload sensitivity.',
			'Policy-as-Code Pipelines: Engineered CI/CD with Git, CodePipeline, and CodeBuild; integrated infrastructure scanning to catch misconfigurations before deployment and reduce drift.',
			'Security Testing: Performed authorized API and application security testing with Burp Suite, OWASP ZAP, and Postman; documented findings, severity, and remediation guidance.',
		],
	},
	{
		role: 'Cloud Technical Support Engineer — Cloud Volumes ONTAP',
		company: 'NetApp Inc',
		dates: '04/2026 - Present',
		location: 'Morrisville, NC',
		bullets: [
			'Multi-Cloud Engineering & Triage: Supports enterprise customers running Cloud Volumes ONTAP across AWS, Azure, and GCP, resolving deployment, IAM, networking, API, licensing, Backup, Replication, Tiering, and outage issues for hybrid and cloud-native storage workloads.',
			'Identity & API: Diagnoses identity, role-assumption, and API authentication failures across cloud providers; uses Postman and curl to reproduce REST calls, validate request signing, isolate misconfigurations, and push workflow that failed from the front end via the API. Analyzing HAR files and packet captures for structured root-cause analysis.',
			'Security Hardening: Guides SSL/TLS certificate binding for VMs, Docker/Podman containers, and cloud volumes; reviews CVE advisories to determine mitigation; resolves firewall-rule and permission issues blocking API calls.',
			'Incident Response & Observability: Analyzes logs across CloudWatch, Kibana, and Grafana; verifies networking, IAM, and certificates to drive structured root-cause analysis; pulls HAR files and packet captures to resolve API and firewall issues.',
			'Resilience & Recovery: Restores customer workloads after ransomware events, region outages, and replication failures using SnapMirror, cross-region replication, and immutable backups.',
			'Knowledge Engineering: Authors solution and how-to articles adopted as reference material across the support organization.',
		],
	},
	{
		role: 'Technical Support Engineer',
		company: 'Perigen Inc',
		dates: '04/2023 - 02/2025',
		location: 'Cary, NC',
		bullets: [
			'Regulated Operations: Supported Windows/Linux and Azure-connected production for FDA-regulated healthcare applications under HIPAA-aligned change control and audit requirements.',
			'Incident Response: Performed structured triage and root-cause analysis across applications, Microsoft SQL Server, server, and network layers to restore service and document remediation.',
			'Hardening & Network Analysis: Implemented SSL/TLS certificate binding, server hardening, and firewall-rule reviews; executed Wireshark packet captures to resolve connectivity, latency, and HL7 integration issues.',
			'Network Troubleshooting: Conducted packet captures and traffic analysis using Wireshark to resolve connectivity, latency, and protocol-level issues affecting workflows.',
			'Employed Postman for API call inspection and troubleshooting; analyzed authentication and request/response behavior to isolate failures.',
			'Automation: Wrote Python and SQL for log analysis, alerting, and proactive monitoring, reducing repeat incidents and improving mean-time-to-detect.',
			'Developed scripts and automation for troubleshooting and alerting, enhancing proactive monitoring and reducing repeat incidents.',
			'Documented resolutions and created operational knowledge artifacts to promote team consistency and expedite speed-to-resolution.',
		],
	},
	{
		role: 'Technical Support - Lead',
		company: 'Infosys Limited',
		dates: '12/2021 - 04/2023',
		location: 'Raleigh, NC',
		bullets: [
			'Leadership: Led incident response and triage for multiple enterprise applications, mentored engineers in structured troubleshooting, and owned escalation management end-to-end.',
			'Hybrid Networking & Automation: Diagnosed cloud / on-prem hybrid networking issues across VPC connectivity and routing; built automation for log analysis and batch monitoring; standardized RCA templates in ServiceNow.',
			'Diagnosed server/performance bottlenecks and improved incident response execution through disciplined triage and effective escalation management.',
			'Delivered application support across mainframe and distributed systems; used ServiceNow for incident tracking and RCA documentation.',
			'Resolved stuck processes and application issues involving COBOL/DB2/SQL.',
		],
	},
	{
		role: 'Production Process Technician',
		company: 'Procter & Gamble',
		dates: '12/2019 - 12/2021',
		location: 'Brown Summit, NC',
		bullets: [
			'Oversaw SCADA/PLC-related operational configurations and resolved system faults that impacted manufacturing workflows.',
			'Ensured compliance-driven execution within regulated environments (FDA/cGMP context).',
		],
	},
	{
		role: 'Program Manager | Web Developer | System Administrator',
		company: 'Sem Fronteiras',
		dates: '11/2010 - 12/2019',
		location: 'Uxbridge, UK',
		bullets: [
			'Developed and maintained IT infrastructure including LAN networks, Linux/Windows servers, workstations, patching, and application deployments.',
			'Created web applications and databases (HTML/CSS/JavaScript/PHP/SQL) and supported operational reporting and stakeholder coordination.',
			'Managed logistics and reporting for healthcare outreach programs, fostering strong execution discipline and operational ownership.',
		],
	},
];

const education = [
	{
		degree: 'Master of Science - Cybersecurity',
		school: 'North Carolina A&T State University',
		dates: '01/2024 - 05/2026',
		location: 'Greensboro, NC',
	},
	{
		degree: 'Bachelor of Science - Information Technology',
		school: 'North Carolina A&T State University',
		dates: '08/2021 - 12/2024',
		location: 'Greensboro, NC',
	},
];

const certificates = [
	{
		certificate: 'AWS Certified Security – Specialty',
	},
	{
		certificate: 'AWS Certified Solutions Architect – Associate',
	},
	{
		certificate: 'DevOps on AWS (Professional Certificate)',
	},
	{
		certificate: 'In Progress:  Certified Cloud Security Professional (CCSP – ISC2)',
	},
	{
		certificate: 'Infosys Certified Mainframe JCL Programmer',
	},
	{
		certificate: 'Infosys Certified COBOL-DB2 Programmer',
	},
];

// Grouped skills - recruiter-scannable instead of one undifferentiated wall.
const skillGroups = [
	{
		label: 'Cloud & Security Architecture',
		items: [
			'AWS', 'Azure', 'IAM / Identity', 'Secure configuration',
			'TLS / Certificate management', 'VPC / VNet patterns', 'Segmentation',
			'Least-privilege policies', 'SSO / OAuth2', 'Azure AD / Entra',
		],
	},
	{
		label: 'DevSecOps & IaC',
		items: [
			'Terraform', 'CloudFormation', 'Git', 'CodePipeline', 'CodeBuild',
			'CI/CD automation', 'Config drift reduction', 'AWS Config',
			'Organizations / Control Tower',
		],
	},
	{
		label: 'AWS Services',
		items: [
			'Identity Center', 'EC2', 'RDS', 'S3', 'VPC', 'Kinesis Firehose',
			'Glue', 'Athena', 'CloudFormation', 'AWS Config',
		],
	},
	{
		label: 'Security & Testing Tools',
		items: [
			'Burp Suite', 'OWASP ZAP', 'Postman', 'Wireshark', 'SSLyze',
			'Penetration testing concepts', 'NIST CSF', 'MITRE ATT&CK',
		],
	},
	{
		label: 'Incident Response & Ops',
		items: [
			'Structured triage', 'Root cause analysis', 'Bridge calls',
			'Escalation management', 'Playbooks & runbooks', 'Splunk',
			'Observability / Logging',
		],
	},
	{
		label: 'Scripting & Data',
		items: [
			'Python', 'Java', 'SQL', 'JavaScript', 'Shell scripting',
			'HL7 concepts', 'Microsoft SQL Server',
		],
	},
	{
		label: 'ITSM & Collaboration',
		items: ['Jira', 'ServiceNow', 'Dynamics 365', 'ClickUp', 'KB authoring'],
	},
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={PAGE_TITLE} description={PAGE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<article class="resume">
				<!-- Header / identity -->
				<header class="resume-head">
					<div class="identity">
						<h1>{contact.name}</h1>
						<p class="tagline">Cloud Security | DevSecOps | AI Infrastructure</p>
					</div>
				</header>

				<!-- Summary -->
				<section class="block">
					<h2>Summary</h2>
					<p class="summary">{summary}</p>
				</section>

				<!-- Experience -->
				<section class="block">
					<h2>Experience</h2>
					{
						experience.map((job) => (
							<div class="job">
								<div class="job-head">
									<h3>
										{job.role} <span class="at">@</span>{' '}
										<span class="company">{job.company}</span>
									</h3>
									<p class="meta">
										<span>{job.dates}</span>
										<span class="dot">"</span>
										<span>{job.location}</span>
									</p>
								</div>
								<ul class="bullets">
									{job.bullets.map((b) => (
										<li>{b}</li>
									))}
								</ul>
							</div>
						))
					}
				</section>

				<!-- Skills -->
				<section class="block">
					<h2>Skills</h2>
					<div class="skill-grid">
						{
							skillGroups.map((group) => (
								<div class="skill-group">
									<h4>{group.label}</h4>
									<ul class="tags">
										{group.items.map((item) => (
											<li>{item}</li>
										))}
									</ul>
								</div>
							))
						}
					</div>
				</section>

				<!-- Education -->
				<section class="block">
					<h2>Education</h2>
					{
						education.map((ed) => (
							<div class="edu">
								<h3>{ed.degree}</h3>
								<p class="meta">
									<span class="company">{ed.school}</span>
									<span class="dot">"</span>
									<span>{ed.dates}</span>
									<span class="dot">"</span>
									<span>{ed.location}</span>
								</p>
							</div>
						))
					}
				</section>

				<!-- Certificates -->
				<section class="block">
					<h2>Certifications</h2>
					{
						certificates.map((cert) => (
							<div class="edu">
								<h3>{cert.certificate}</h3>
							</div>
						))
					}
				</section>

			</article>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		width: 820px;
		max-width: calc(100% - 2em);
		margin: 0 auto;
	}

	.resume {
		margin: 2rem 0 4rem;
		color: rgb(var(--gray-dark));
	}

	/* ---- Identity header ---- */
	.resume-head {
		display: grid;
		grid-template-columns: 1fr auto;
		grid-template-areas:
			'identity pdf'
			'contact  contact';
		gap: 0.75rem 1rem;
		align-items: start;
		padding-bottom: 1.25rem;
		border-bottom: 1px solid rgba(var(--gray), 0.35);
	}
	.identity {
		grid-area: identity;
	}
	.identity h1 {
		margin: 0;
		font-size: 2.2rem;
		line-height: 1.1;
		color: rgb(var(--black));
	}
	.tagline {
		margin: 0.35rem 0 0;
		color: rgb(var(--accent));
		font-weight: 600;
		letter-spacing: 0.01em;
	}
	.contact {
		grid-area: contact;
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem 1.1rem;
		margin: 0;
		padding: 0;
		list-style: none;
		font-size: 0.9rem;
	}
	.contact a {
		color: rgb(var(--gray-dark));
		text-decoration: none;
		border-bottom: 1px solid transparent;
		transition: border-color 0.2s ease, color 0.2s ease;
	}
	.contact a:hover {
		color: rgb(var(--accent));
		border-bottom-color: rgb(var(--accent));
	}

	/* ---- PDF button (echoes the site's terminal motif) ---- */
	.pdf-btn {
		grid-area: pdf;
		display: inline-flex;
		align-items: center;
		gap: 0.5em;
		font-family: 'JetBrains Mono', ui-monospace, monospace;
		font-size: 0.8rem;
		font-weight: 500;
		line-height: 1.2;
		text-decoration: none;
		background: #161b22;
		border: 1px solid rgba(77, 139, 255, 0.45);
		padding: 0.45em 0.85em;
		border-radius: 999px;
		white-space: nowrap;
		transition: transform 0.22s ease, box-shadow 0.22s ease,
			border-color 0.22s ease, background 0.22s ease;
	}
	.pdf-btn:hover {
		background: #1b2330;
		border-color: #4d8bff;
		transform: translateY(-2px);
		box-shadow: 0 10px 26px -8px rgba(77, 139, 255, 0.55);
	}
	.pdf-btn .rb-prompt {
		color: #5b6b7d;
	}
	.pdf-btn .rb-cmd {
		color: #e6edf3;
	}

	/* ---- Section blocks ---- */
	.block {
		margin-top: 2.25rem;
	}
	.block h2 {
		font-family: 'JetBrains Mono', ui-monospace, monospace;
		font-size: 1.05rem;
		font-weight: 600;
		color: rgb(var(--black));
		margin: 0 0 1rem;
		padding-bottom: 0.4rem;
		border-bottom: 2px solid rgba(var(--gray), 0.3);
	}
	.prompt {
		color: rgb(var(--accent));
		margin-right: 0.5ch;
		user-select: none;
	}

	.summary {
		margin: 0;
		line-height: 1.6;
	}

	/* ---- Experience ---- */
	.job {
		margin-bottom: 1.75rem;
	}
	.job:last-child {
		margin-bottom: 0;
	}
	.job-head h3 {
		margin: 0;
		font-size: 1.1rem;
		color: rgb(var(--black));
	}
	.job-head .at {
		color: rgb(var(--gray));
		font-weight: 400;
	}
	.company {
		color: rgb(var(--accent));
	}
	.meta {
		margin: 0.2rem 0 0.6rem;
		font-size: 0.85rem;
		color: rgb(var(--gray));
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
		align-items: center;
	}
	.meta .dot {
		opacity: 0.6;
	}
	.bullets {
		margin: 0;
		padding-left: 1.1rem;
		display: grid;
		gap: 0.4rem;
	}
	.bullets li {
		line-height: 1.5;
	}

	/* ---- Skills ---- */
	.skill-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1.25rem 2rem;
	}
	.skill-group h4 {
		margin: 0 0 0.5rem;
		font-size: 0.8rem;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: rgb(var(--gray));
	}
	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
		margin: 0;
		padding: 0;
		list-style: none;
	}
	.tags li {
		font-size: 0.82rem;
		padding: 0.2em 0.65em;
		border: 1px solid rgba(var(--gray), 0.4);
		border-radius: 999px;
		color: rgb(var(--gray-dark));
		background: rgba(var(--gray-light), 0.4);
	}
	.tags.inline {
		margin-top: 0;
	}

	/* ---- Education ---- */
	.edu {
		margin-bottom: 1rem;
	}
	.edu h3 {
		margin: 0;
		font-size: 1.02rem;
		color: rgb(var(--black));
	}

	/* ---- Responsive ---- */
	@media (max-width: 720px) {
		.resume-head {
			grid-template-columns: 1fr;
			grid-template-areas:
				'identity'
				'pdf'
				'contact';
		}
		.pdf-btn {
			justify-self: start;
		}
		.skill-grid {
			grid-template-columns: 1fr;
		}
		.identity h1 {
			font-size: 1.8rem;
		}
	}

	/* ---- Print: clean ATS / paper output ---- */
	@media print {
		.pdf-btn {
			display: none;
		}
		main {
			width: 100%;
			max-width: 100%;
		}
		.block h2,
		.prompt,
		.company,
		.tagline {
			color: #000 !important;
		}
		.tags li {
			border-color: #999;
			background: transparent;
		}
	}
</style>